@using CollegeManagement.Helper
@using Microsoft.AspNetCore.Components.Authorization

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">CollegeManagement</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <AuthorizeView Roles="Admin">
            @* Admin *@
            @* AdminRoutes *@
            @foreach (NavigationItem item in adminNav)
            {
                <div class="nav-item px-3">
                    <NavLink href="@item.Url" class="nav-link">
                        @item.Title
                    </NavLink>
                </div>
            }
        </AuthorizeView>

        <AuthorizeView Roles="Lecturer">
            @* Lecturer *@
            @* Lecturer Routes *@

            @foreach (NavigationItem item in lecturerNav)
            {
                <div class="nav-item px-3">
                    <NavLink href="@item.Url" class="nav-link">
                        @item.Title
                    </NavLink>
                </div>
            }
        </AuthorizeView>
        <AuthorizeView Roles="Student">
            @* Student *@
            @* Student Routes *@
            @foreach (NavigationItem item in studentNav)
            {
                <div class="nav-item px-3">
                    <NavLink href="@item.Url" class="nav-link">
                        @item.Title
                    </NavLink>
                </div>
            }
        </AuthorizeView>


        


   


    
       

     
    </nav>
</div>


@code{
    private List<NavigationItem> adminNav = new();
    private List<NavigationItem> lecturerNav = new();
    private List<NavigationItem> studentNav = new();

    protected override void OnInitialized()
    {
        adminNav = NavigationProvider.GetMenu("Admin");
        lecturerNav = NavigationProvider.GetMenu("Lecturer");
        studentNav = NavigationProvider.GetMenu("Student");
    }

}

